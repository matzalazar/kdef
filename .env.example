# kdef — Variables de entorno
# Copiar este archivo a .env y completar con valores reales
# NUNCA commitear el .env al repositorio

# =============================================================================
# Moodle — Credenciales del aula virtual de la UNDEF
# =============================================================================

# URL base del Moodle de la UNDEF (sin slash final)
# Ejemplo: https://moodle.undef.edu.ar
MOODLE_URL=https://campus.fadena.undef.edu.ar

# Nombre de usuario de tu cuenta de Moodle de la UNDEF
MOODLE_USER=tu.usuario.de.moodle

# Contraseña de tu cuenta de Moodle de la UNDEF
# Ojo: esta variable es sensible — no logguear su valor
MOODLE_PASS=tu-contrasena-de-moodle

# =============================================================================
# LLMs — Modelos de lenguaje para generación de resúmenes
# =============================================================================

# API key de GitHub Models (LLM primario)
# Obtener en: github.com/settings/tokens
# El pipeline usa esto para acceder a la API de GitHub Models
GITHUB_MODELS_KEY=ghp_...

# API key de OpenRouter (LLM secundario)
# Obtener en: openrouter.ai/keys
# Se usa si GitHub Models no está disponible. Tiene modelos gratuitos con rate limit diario renovable.
# Modelo por defecto: meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=sk-or-...

# API key de Google Gemini (LLM terciario / fallback)
# Obtener en: aistudio.google.com/app/apikey
# Se usa solo si GitHub Models y OpenRouter no están disponibles
GEMINI_API_KEY=AIzaSy...

# =============================================================================
# Cloudflare — Deploy a Cloudflare Pages
# =============================================================================

# Token de API de Cloudflare con permisos sobre Cloudflare Pages
# Obtener en: dash.cloudflare.com/profile/api-tokens
# Template recomendado: "Edit Cloudflare Pages"
CF_API_TOKEN=...

# ID de tu cuenta de Cloudflare
# Se encuentra en el panel de Cloudflare (barra lateral derecha de cualquier página)
CF_ACCOUNT_ID=...

# =============================================================================
# Pipeline — Control del comportamiento del pipeline
# (Normalmente no hace falta modificar estos en producción)
# =============================================================================

# Lista de slugs de materias a trackear desde config/campus.yml.
# Usá "all" para incluir todas las materias habilitadas.
TRACKED_SUBJECTS=all

# Activar modo dry-run: el pipeline corre pero no escribe archivos ni hace commit
# Útil para probar el pipeline sin efectos secundarios
# Valores válidos: "true" | "false"
DRY_RUN=false

# Forzar re-procesamiento de todos los documentos ignorando el manifest
# Útil cuando cambia el prompt del LLM o se quiere regenerar todo el contenido
# Valores válidos: "true" | "false"
FORCE_REPROCESS=false
